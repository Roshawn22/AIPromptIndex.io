---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import PromptFilter from '../../components/prompt/PromptFilter';

import toolsJson from '../../data/tools/tools.json';
import categoriesJson from '../../data/categories/categories.json';

const allPrompts = await getCollection('prompts');

// Serialize to plain objects for the React island
const prompts = allPrompts.map((p) => ({
  title: p.data.title,
  slug: p.data.slug,
  description: p.data.description,
  tool: p.data.tool,
  category: p.data.category,
  difficulty: p.data.difficulty,
  tags: p.data.tags ?? [],
  isFeatured: p.data.isFeatured ?? false,
  dateAdded: p.data.dateAdded,
}));

const tools = toolsJson.map((t: any) => ({ id: t.id, name: t.name, slug: t.slug }));
const categories = categoriesJson.map((c: any) => ({ id: c.id, name: c.name, slug: c.slug }));

const discoveryLinks = [
  {
    title: 'Best AI Prompts',
    description: 'Start with the highest-rated prompts across every tool and category.',
    href: '/best/best-ai-prompts/',
  },
  {
    title: 'Free AI Prompts',
    description: 'Prompts built for useful results without a paid AI subscription.',
    href: '/best/free-ai-prompts/',
  },
  {
    title: 'Image Generation Prompts',
    description: 'Browse AI art, logo, product photo, thumbnail, and visual prompt examples.',
    href: '/categories/image-generation/',
  },
  {
    title: 'Prompt Templates',
    description: 'Use reusable fill-in-the-blank structures for repeatable AI workflows.',
    href: '/best/prompt-templates/',
  },
];
---

<BaseLayout
  title="AI Prompt Catalog | Browse Free Prompt Templates"
  description="Explore a curated AI prompt catalog for ChatGPT, Claude, Midjourney, and more. Filter free prompt templates by tool, category, and difficulty level."
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-12">
    <div class="mb-10">
      <h1>All Prompts</h1>
      <p class="mt-2 text-lg text-[var(--color-text-secondary)]">
        {prompts.length} curated prompts across {new Set(prompts.map(p => p.category)).size} categories
      </p>
      <div class="mt-5 flex flex-wrap gap-3 text-sm">
        <a
          href="/best/free-ai-prompts/"
          class="surface-solid-content rounded-full px-4 py-2 font-medium text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-accent)]"
        >
          Free AI prompt library
        </a>
        <a
          href="/best/best-ai-prompts/"
          class="surface-solid-content rounded-full px-4 py-2 font-medium text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-accent)]"
        >
          Best AI prompt catalog
        </a>
        <a
          href="/guides/prompt-engineering-101/"
          class="surface-solid-content rounded-full px-4 py-2 font-medium text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-accent)]"
        >
          Prompt engineering guide
        </a>
      </div>
    </div>

    <div class="mb-10 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
      {discoveryLinks.map((link) => (
        <a
          href={link.href}
          class="surface-glass-ui group rounded-[var(--radius-lg)] p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
        >
          <h2 class="text-base font-[var(--font-display)] font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)]">
            {link.title}
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {link.description}
          </p>
          <span class="mt-4 inline-flex text-sm font-medium text-[var(--color-accent)]">
            Browse &rarr;
          </span>
        </a>
      ))}
    </div>

    <PromptFilter
      client:load
      prompts={prompts}
      tools={tools}
      categories={categories}
    />
  </section>

  <Footer slot="footer" />
</BaseLayout>
