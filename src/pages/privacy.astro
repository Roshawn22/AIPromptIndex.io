---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for AIPromptIndex.io"
  noindex={true}
>
  <Header slot="header" />

  <section class="mx-auto max-w-3xl px-[var(--space-page)] py-16">
    <h1>Privacy Policy</h1>
    <p class="mt-2 text-sm text-[var(--color-text-muted)]">Last updated: April 1, 2026</p>
    <div class="mt-8 space-y-6 text-[var(--color-text-secondary)] leading-relaxed">
      <p>AIPromptIndex.io ("we", "our", "us") is committed to protecting your privacy. This policy explains how we collect and use your information.</p>

      <h2 class="!mt-8 text-xl text-[var(--color-text-primary)]">Information We Collect</h2>
      <ul class="list-disc list-inside space-y-2">
        <li>Usage data via Google Analytics (anonymized IP, page views, referrers)</li>
        <li>Email address if you subscribe to our newsletter</li>
        <li>Information you provide when submitting prompts</li>
      </ul>

      <h2 class="!mt-8 text-xl text-[var(--color-text-primary)]">How We Use Information</h2>
      <ul class="list-disc list-inside space-y-2">
        <li>To improve our directory and user experience</li>
        <li>To send newsletter updates (with your consent)</li>
        <li>To display relevant advertisements via Google AdSense</li>
      </ul>

      <h2 class="!mt-8 text-xl text-[var(--color-text-primary)]">Third-Party Services</h2>
      <p>We use Google Analytics, Google AdSense, Beehiiv (newsletter), and Convex (database). Each has their own privacy policy.</p>

      <h2 class="!mt-8 text-xl text-[var(--color-text-primary)]">Contact</h2>
      <p>For privacy questions, contact us at <a href="/contact/" class="text-[var(--color-accent)] hover:underline">our contact page</a>.</p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
