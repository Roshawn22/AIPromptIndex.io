---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import PromptCard from '../../components/prompt/PromptCard.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const allPrompts = await getCollection('prompts');
const prompts = allPrompts
  .filter((p) => p.data.tool === tool.data.slug)
  .sort((a, b) => {
    if (a.data.isFeatured && !b.data.isFeatured) return -1;
    if (!a.data.isFeatured && b.data.isFeatured) return 1;
    return new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime();
  });
---

<BaseLayout
  title={`Best ${tool.data.name} Prompts`}
  description={`Browse ${prompts.length} free ${tool.data.name} prompts for ${tool.data.name}. Copy-ready templates help you customize examples, improve AI outputs, and build a reusable prompt library.`}
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Tools', href: '/tools/' },
      { label: tool.data.name },
    ]} />

    <div class="mb-10">
      <h1>Best {tool.data.name} Prompts</h1>
      <p class="mt-2 text-lg text-[var(--color-text-secondary)]">
        {prompts.length} curated prompts for {tool.data.name}
      </p>
      <p class="mt-4 text-[var(--color-text-secondary)]">{tool.data.description}</p>

      <!-- Action buttons -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {tool.data.affiliateUrl && (
          <a
            href={tool.data.affiliateUrl}
            target="_blank"
            rel="noopener sponsored"
            class="inline-flex items-center gap-2 rounded-[var(--radius-md)] bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-teal-600"
          >
            Visit {tool.data.name}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
            </svg>
          </a>
        )}
        <a
          href={`https://aitoolindex.io/tools/${tool.data.slug}/`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border-2 border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          See full review on AIToolIndex.io
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="https://www.skool.com/ai-freedom-lab"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border-2 border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text-secondary)] transition-colors hover:border-amber-500 hover:text-amber-500"
        >
          Join AI Freedom Lab to discuss {tool.data.name} prompts
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </a>
      </div>
    </div>

    {prompts.length > 0 ? (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {prompts.map((prompt) => (
          <PromptCard
            title={prompt.data.title}
            slug={prompt.data.slug}
            description={prompt.data.description}
            tool={prompt.data.tool}
            category={prompt.data.category}
            difficulty={prompt.data.difficulty}
            tags={prompt.data.tags}
            isFeatured={prompt.data.isFeatured}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-[var(--color-text-muted)] py-12">
        No prompts for {tool.data.name} yet. <a href="/submit/" class="text-[var(--color-accent)] hover:underline">Submit one!</a>
      </p>
    )}
  </section>

  <Footer slot="footer" />
</BaseLayout>
