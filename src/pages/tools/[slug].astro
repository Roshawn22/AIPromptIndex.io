---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import PromptCard from '../../components/prompt/PromptCard.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import { CATEGORY_DISPLAY_NAMES as categoryDisplayNames } from '../../lib/constants';
import { promptMatchesBestOfFilter } from '../../lib/bestof';
import toolCategoryPages from '../../data/seo/tool-category-pages.json';
import bestofPages from '../../data/seo/bestof-pages.json';
import audiencePages from '../../data/seo/audience-pages.json';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const allPrompts = await getCollection('prompts');
const allGuides = await getCollection('guides');
const allPosts = await getCollection('blog');
const prompts = allPrompts
  .filter((p) => p.data.tool === tool.data.slug)
  .sort((a, b) => {
    if (a.data.isFeatured && !b.data.isFeatured) return -1;
    if (!a.data.isFeatured && b.data.isFeatured) return 1;
    return new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime();
  });

const categoryCounts = prompts.reduce((acc, prompt) => {
  acc[prompt.data.category] = (acc[prompt.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const topCategories = Object.entries(categoryCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 4)
  .map(([slug, count]) => ({
    slug,
    count,
    name: categoryDisplayNames[slug] || slug,
  }));

const toolCollections = toolCategoryPages
  .filter((page: any) => page.tool === tool.data.slug)
  .slice(0, 6);

const toolRoundups = bestofPages
  .filter((page: any) => (
    page.filter?.tool === tool.data.slug ||
    (page.filter?.promptSlugs?.length && prompts.some((prompt) => promptMatchesBestOfFilter(prompt, page.filter)))
  ))
  .slice(0, 4);

const audienceMatches = audiencePages
  .map((page: any) => {
    const count = prompts.filter((prompt) => {
      const categoryMatch = page.filterCategories?.includes(prompt.data.category);
      const tagMatch = page.filterTags?.some((tag: string) => prompt.data.tags?.includes(tag));
      return categoryMatch || tagMatch;
    }).length;

    return { ...page, count };
  })
  .filter((page: any) => page.count > 0)
  .sort((a: any, b: any) => b.count - a.count)
  .slice(0, 4);

const currentYear = new Date().getFullYear();
const topCategorySummary = topCategories.map((category) => category.name).join(', ');
const seoTitle = `Best ${tool.data.name} Prompts (${currentYear}) — ${prompts.length} Free Prompts`;
const seoDescription = `Browse ${prompts.length} free ${tool.data.name} prompts for ${topCategorySummary || 'popular use cases'}. Copy-ready templates help you customize examples, improve AI outputs, and build a reusable prompt library.`;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://aipromptindex.io';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Best ${tool.data.name} Prompts`,
  description: seoDescription,
  numberOfItems: prompts.length,
  itemListElement: prompts.map((prompt, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: prompt.data.title,
    url: `${siteUrl}/prompts/${prompt.data.slug}/`,
  })),
};

const editorialEntryMap = {
  blog: new Map(allPosts.map((entry) => [entry.id, entry])),
  guide: new Map(allGuides.map((entry) => [entry.id, entry])),
};

const editorialResourceMap: Record<string, Array<{ type: 'blog' | 'guide'; slug: string }>> = {
  chatgpt: [
    { type: 'blog', slug: 'best-chatgpt-prompts-2026' },
    { type: 'guide', slug: 'chatgpt-for-business' },
    { type: 'blog', slug: 'chatgpt-vs-claude-prompting-differences' },
  ],
  claude: [
    { type: 'blog', slug: 'chatgpt-vs-claude-prompting-differences' },
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
  gemini: [
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
    { type: 'guide', slug: 'chatgpt-for-business' },
  ],
  midjourney: [
    { type: 'guide', slug: 'midjourney-prompt-guide' },
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
  'dall-e': [
    { type: 'guide', slug: 'midjourney-prompt-guide' },
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
  'stable-diffusion': [
    { type: 'guide', slug: 'midjourney-prompt-guide' },
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
  cursor: [
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'chatgpt-vs-claude-prompting-differences' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
  'github-copilot': [
    { type: 'guide', slug: 'prompt-engineering-101' },
    { type: 'blog', slug: 'chatgpt-vs-claude-prompting-differences' },
    { type: 'blog', slug: 'how-to-write-ai-prompts-beginners-guide' },
  ],
};

const editorialResources = (editorialResourceMap[tool.data.slug] || [])
  .map((resource) => {
    const entry = editorialEntryMap[resource.type].get(resource.slug);
    if (!entry) return null;

    return {
      href: `/${resource.type === 'blog' ? 'blog' : 'guides'}/${resource.slug}/`,
      label: resource.type === 'blog' ? 'Blog' : 'Guide',
      title: entry.data.metaTitle || entry.data.title,
      description: entry.data.metaDescription || entry.data.description,
    };
  })
  .filter(Boolean);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  jsonLd={[itemListJsonLd]}
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Tools', href: '/tools/' },
      { label: tool.data.name },
    ]} />

    <div class="mb-10">
      <h1>Best {tool.data.name} Prompts</h1>
      <p class="mt-2 text-lg text-[var(--color-text-secondary)]">
        {prompts.length} curated prompts for {tool.data.name}
      </p>
      <p class="mt-4 text-[var(--color-text-secondary)]">{tool.data.description}</p>
      {topCategories.length > 0 && (
        <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">
          Use these {tool.data.name} prompts for {topCategories.map((category, index) => (
            <span>
              <a href={`/prompts/${tool.data.slug}/${category.slug}/`} class="text-[var(--color-accent)] hover:underline">
                {category.name.toLowerCase()}
              </a>
              {index < topCategories.length - 1 ? ', ' : ''}
            </span>
          ))}. Each collection is organized by use case and designed to be copied into {tool.data.name} with minimal editing.
        </p>
      )}

      <!-- Action buttons -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {tool.data.affiliateUrl && (
          <a
            href={tool.data.affiliateUrl}
            target="_blank"
            rel="noopener sponsored"
            class="inline-flex items-center gap-2 rounded-[var(--radius-md)] bg-[var(--color-accent)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-teal-600"
          >
            Visit {tool.data.name}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
            </svg>
          </a>
        )}
        <a
          href={`https://aitoolindex.io/tools/${tool.data.slug}/`}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border-2 border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          See full review on AIToolIndex.io
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="https://www.skool.com/ai-freedom-lab"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border-2 border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text-secondary)] transition-colors hover:border-amber-500 hover:text-amber-500"
        >
          Join AI Freedom Lab to discuss {tool.data.name} prompts
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </a>
      </div>
    </div>

    {prompts.length > 0 ? (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {prompts.map((prompt) => (
          <PromptCard
            title={prompt.data.title}
            slug={prompt.data.slug}
            description={prompt.data.description}
            tool={prompt.data.tool}
            category={prompt.data.category}
            difficulty={prompt.data.difficulty}
            tags={prompt.data.tags}
            isFeatured={prompt.data.isFeatured}
          />
        ))}
      </div>
    ) : (
      <p class="text-center text-[var(--color-text-muted)] py-12">
        No prompts for {tool.data.name} yet. <a href="/submit/" class="text-[var(--color-accent)] hover:underline">Submit one!</a>
      </p>
    )}

    {toolCollections.length > 0 && (
      <div class="mt-16 border-t border-[var(--color-border)] pt-10">
        <h2 class="mb-6 text-xl">Popular {tool.data.name} Collections</h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          {toolCollections.map((collection: any) => (
            <a
              href={`/prompts/${collection.tool}/${collection.category}/`}
              class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-5 transition-all duration-200 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
            >
              <h3 class="font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)]">
                {collection.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                {collection.metaDescription}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    {editorialResources.length > 0 && (
      <div class="mt-16 border-t border-[var(--color-border)] pt-10">
        <h2 class="mb-6 text-xl">Guides and Articles for {tool.data.name}</h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          {editorialResources.map((resource: any) => (
            <a
              href={resource.href}
              class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-5 transition-all duration-200 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
            >
              <span class="inline-flex rounded-full bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-[var(--font-display)] font-semibold uppercase tracking-wider text-[var(--color-accent)]">
                {resource.label}
              </span>
              <h3 class="mt-4 font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)]">
                {resource.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                {resource.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    {audienceMatches.length > 0 && (
      <div class="mt-16 border-t border-[var(--color-border)] pt-10">
        <h2 class="mb-6 text-xl">Who Uses {tool.data.name} Prompts</h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
          {audienceMatches.map((page: any) => (
            <a
              href={`/prompts/for/${page.slug}/`}
              class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-5 transition-all duration-200 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
            >
              <h3 class="font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)]">
                {page.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                {page.metaDescription}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    {toolRoundups.length > 0 && (
      <div class="mt-16 border-t border-[var(--color-border)] pt-10">
        <h2 class="mb-6 text-xl">Best-of Pages for {tool.data.name}</h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
          {toolRoundups.map((page: any) => (
            <a
              href={`/best/${page.slug}/`}
              class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-5 transition-all duration-200 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
            >
              <h3 class="font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)]">
                {page.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
                {page.metaDescription || page.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</BaseLayout>
