---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Badge from '../components/ui/Badge.astro';
import NewsletterSignup from '../components/common/NewsletterSignup.astro';
import PromptCard from '../components/prompt/PromptCard.astro';
import HeroEntrance from '../components/motion/HeroEntrance';
import CategoryGrid from '../components/motion/CategoryGrid';
import CollectionGrid from '../components/motion/CollectionGrid';
import { getCollection } from 'astro:content';
import { TOOL_DISPLAY_NAMES as toolDisplayNames } from '../lib/constants';

const allPrompts = await getCollection('prompts');

const featuredPrompts = allPrompts
  .filter((p) => p.data.isFeatured)
  .slice(0, 8);

const latestPrompts = [...allPrompts]
  .sort((a, b) => new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime())
  .slice(0, 5);

const categories = [
  { name: 'Writing', slug: 'writing', description: 'Blog posts, emails, copywriting' },
  { name: 'Coding', slug: 'coding', description: 'Code generation, debugging, review' },
  { name: 'Marketing', slug: 'marketing', description: 'Campaigns, social media, SEO' },
  { name: 'Image Generation', slug: 'image-generation', description: 'AI art, logos, illustrations' },
  { name: 'Business', slug: 'business', description: 'Strategy, analysis, operations' },
  { name: 'Data Analysis', slug: 'data-analysis', description: 'Exploration, visualization, reports' },
  { name: 'Education', slug: 'education', description: 'Learning, tutoring, study aids' },
  { name: 'Creative', slug: 'creative', description: 'Storytelling, brainstorming, ideation' },
];

const tools = [
  { name: 'ChatGPT', slug: 'chatgpt', color: '#10a37f' },
  { name: 'Claude', slug: 'claude', color: '#d4a574' },
  { name: 'Gemini', slug: 'gemini', color: '#4285f4' },
  { name: 'Midjourney', slug: 'midjourney', color: '#ffffff' },
  { name: 'DALL-E', slug: 'dall-e', color: '#10a37f' },
  { name: 'Cursor', slug: 'cursor', color: '#000000' },
  { name: 'GitHub Copilot', slug: 'github-copilot', color: '#000000' },
  { name: 'Stable Diffusion', slug: 'stable-diffusion', color: '#a855f7' },
];

const collections = [
  { title: 'Free AI Prompt Library', description: 'Copy-ready prompts grouped for free AI tool tiers and repeatable workflows.', href: '/best/free-ai-prompts/' },
  { title: 'Best AI Prompt Catalog', description: 'Start with the strongest prompts across every tool, category, and use case.', href: '/best/best-ai-prompts/' },
  { title: 'Best ChatGPT Prompts for Marketing', description: 'High-converting marketing prompts for campaigns, ad copy, and content strategy.', href: '/prompts/chatgpt/marketing/' },
  { title: 'AI Prompts for Teachers', description: 'Lesson plans, quizzes, rubrics, and differentiated instruction materials.', href: '/prompts/for/teachers/' },
  { title: 'Best Cursor Coding Prompts', description: 'Code generation, refactoring, debugging, and multi-file editing prompts.', href: '/prompts/cursor/coding/' },
  { title: 'DALL-E Art Prompts', description: 'Creative prompts for illustrations, concept art, and visual design.', href: '/best/dall-e-art-prompts/' },
  { title: 'AI Prompts for Entrepreneurs', description: 'Validate ideas, build MVPs, create pitch decks, and grow startups.', href: '/prompts/for/entrepreneurs/' },
  { title: 'Best Claude Writing Prompts', description: 'Leverage Claude\'s nuanced writing for blog posts, essays, and long-form content.', href: '/prompts/claude/writing/' },
  { title: 'AI Resume Prompts', description: 'Rewrite resumes, tailor cover letters, and turn job history into ATS-friendly achievements.', href: '/best/resume-ai-prompts/' },
  { title: 'SEO Prompts', description: 'Keyword research, content briefs, meta descriptions, and on-page SEO workflows.', href: '/best/seo-prompts/' },
  { title: 'ChatGPT Business Prompts', description: 'Business planning, operations, customer communication, and strategy prompts for ChatGPT.', href: '/best/chatgpt-business-prompts/' },
  { title: 'ChatGPT Prompts for Students', description: 'Study guides, flashcards, Socratic tutoring, and exam prep prompts for students.', href: '/best/chatgpt-prompts-for-students/' },
];

const startHereResources = [
  {
    title: 'Prompt Engineering for Beginners',
    description: 'Start with the core prompt-engineering patterns, examples, and copy-ready structures.',
    href: '/guides/prompt-engineering-101/',
    label: 'Guide',
  },
  {
    title: 'Best ChatGPT Prompts for 2026',
    description: 'A fast entry point for high-performing writing, marketing, business, and productivity prompts.',
    href: '/blog/best-chatgpt-prompts-2026/',
    label: 'Blog',
  },
  {
    title: 'AI Business Plan Prompts',
    description: 'Use Claude and ChatGPT prompts for executive summaries, market analysis, pitch decks, and funding narratives.',
    href: '/best/ai-business-plan-prompts/',
    label: 'Business',
  },
  {
    title: 'Best Stable Diffusion Prompts',
    description: 'Browse proven prompts for portraits, fantasy scenes, product shots, and photorealistic images.',
    href: '/best/stable-diffusion-prompts/',
    label: 'Roundup',
  },
  {
    title: 'AI Prompt Templates',
    description: 'Use fill-in-the-blank prompt templates you can adapt across ChatGPT, Claude, Gemini, and more.',
    href: '/best/prompt-templates/',
    label: 'Templates',
  },
  {
    title: 'Free AI Prompt Library',
    description: 'Browse the free prompt library and AI prompt catalog by task, tool, category, and reusable template format.',
    href: '/best/free-ai-prompts/',
    label: 'Free',
  },
  {
    title: 'Best AI Prompts',
    description: 'Start with the highest-rated prompts across every major tool, category, and repeatable workflow.',
    href: '/best/best-ai-prompts/',
    label: 'Best',
  },
  {
    title: 'Image Prompt Browser',
    description: 'Jump straight into AI art, product photo, logo, thumbnail, and visual prompt examples.',
    href: '/categories/image-generation/',
    label: 'Images',
  },
];

const editorialResources = [
  {
    title: 'Best ChatGPT Prompts for 2026',
    description: 'A curated list of tested prompts for writing, business, coding, and productivity workflows.',
    href: '/blog/best-chatgpt-prompts-2026/',
    label: 'Blog',
  },
  {
    title: 'How to Write AI Prompts',
    description: 'A practical beginner guide to prompt engineering with reusable structures and examples.',
    href: '/blog/how-to-write-ai-prompts-beginners-guide/',
    label: 'Guide',
  },
  {
    title: 'ChatGPT vs Claude Prompting',
    description: 'See how prompting style changes between the two most-used general AI assistants.',
    href: '/blog/chatgpt-vs-claude-prompting-differences/',
    label: 'Comparison',
  },
  {
    title: 'Prompt Engineering 101',
    description: 'Learn the five pillars of strong prompts and how to turn them into reusable templates.',
    href: '/guides/prompt-engineering-101/',
    label: 'Guide',
  },
  {
    title: 'ChatGPT for Business',
    description: 'Twenty real business prompts for marketing, sales, operations, HR, and finance tasks.',
    href: '/guides/chatgpt-for-business/',
    label: 'Guide',
  },
  {
    title: 'Midjourney Prompt Guide',
    description: 'A practical reference for structure, style keywords, and advanced image-prompt techniques.',
    href: '/guides/midjourney-prompt-guide/',
    label: 'Guide',
  },
];
---

<BaseLayout
  title="Free AI Prompt Library for ChatGPT, Claude & More"
  description="Browse a free AI prompt library with prompt templates for ChatGPT, Claude, Midjourney, Gemini, Cursor, and more. Copy, customize, and use them fast."
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative overflow-hidden border-b border-[var(--glass-border)]">
    <div class="absolute top-0 left-1/4 h-96 w-96 rounded-full bg-teal-500/5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-1/4 h-96 w-96 rounded-full bg-amber-500/5 blur-3xl" aria-hidden="true"></div>

    <HeroEntrance promptCount={allPrompts.length} client:load />
  </section>

  <!-- Tool Quick-Filter Bar -->
  <section class="border-b border-[var(--glass-border)] bg-transparent">
    <div class="mx-auto max-w-7xl px-[var(--space-page)] py-4">
      <div class="surface-glass-prominent flex items-center gap-3 overflow-x-auto rounded-full px-4 py-3 scrollbar-none scroll-fade-x">
        <span class="shrink-0 text-xs font-[var(--font-display)] font-medium uppercase tracking-wider text-[var(--color-text-muted)]">
          By Tool:
        </span>
        {tools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="glass-pill-compact shrink-0"
          >
            {tool.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-16 border-b border-[var(--color-border)]" data-reveal>
    <div class="mb-10 flex items-end justify-between">
      <div class="section-head-copy">
        <h2 class="text-[var(--color-text-primary)]">Start With the Free Prompt Library</h2>
        <p class="mt-2 max-w-2xl text-[var(--color-text-secondary)]">
          These are the fastest paths into the AI prompt catalog if you want a searchable prompt database, prompt examples, prompt templates, or beginner-friendly guidance.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      {startHereResources.map((resource) => (
        <a
          href={resource.href}
          class="surface-glass-prominent group rounded-[var(--radius-lg)] p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
        >
          <span class="inline-flex rounded-full bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-[var(--font-display)] font-semibold uppercase tracking-wider text-[var(--color-accent)]">
            {resource.label}
          </span>
          <h3 class="mt-4 text-lg font-[var(--font-display)] font-semibold text-[var(--color-text-primary)]">
            {resource.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {resource.description}
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-[var(--color-accent)]">
            Open resource &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl border-t border-[var(--color-border)] px-[var(--space-page)] py-16" data-reveal>
    <div class="mb-10 flex items-end justify-between">
      <div class="section-head-copy">
        <h2 class="text-[var(--color-text-primary)]">Learn Prompting Faster</h2>
        <p class="mt-2 max-w-2xl text-[var(--color-text-secondary)]">
          Use these guides and articles to understand how the library works, pick better tools, and improve your prompts before you customize them.
        </p>
      </div>
      <a href="/guides/" class="hidden text-sm font-[var(--font-display)] font-medium text-[var(--color-accent)] hover:underline sm:block">
        View all guides &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      {editorialResources.map((resource) => (
        <a
          href={resource.href}
          class="surface-glass-prominent group rounded-[var(--radius-lg)] p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--color-accent-muted)] hover:shadow-[var(--shadow-card-hover)]"
        >
          <span class="inline-flex rounded-full bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-[var(--font-display)] font-semibold uppercase tracking-wider text-[var(--color-accent)]">
            {resource.label}
          </span>
          <h3 class="mt-4 text-lg font-[var(--font-display)] font-semibold text-[var(--color-text-primary)]">
            {resource.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {resource.description}
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-[var(--color-accent)]">
            Open resource &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-16" data-reveal>
    <div class="mb-10 flex items-end justify-between">
      <div class="section-head-copy">
        <h2 class="text-[var(--color-text-primary)]">Browse by Use Case</h2>
        <p class="mt-2 max-w-xl text-[var(--color-text-secondary)]">Find the perfect prompt for your next project</p>
      </div>
      <a href="/categories/" class="hidden text-sm font-[var(--font-display)] font-medium text-[var(--color-accent)] hover:underline sm:block">
        View all categories &rarr;
      </a>
    </div>

    <CategoryGrid categories={categories} client:visible />
  </section>

  <!-- Featured Prompts -->
  {featuredPrompts.length > 0 && (
    <section class="mx-auto max-w-7xl px-[var(--space-page)] py-16 border-t border-[var(--color-border)]" data-reveal>
      <div class="mb-10 flex items-end justify-between">
        <div class="section-head-copy">
          <h2 class="text-[var(--color-text-primary)]">Featured Prompts</h2>
          <p class="mt-2 max-w-xl text-[var(--color-text-secondary)]">Editor's picks &mdash; our most popular and effective prompts</p>
        </div>
        <a href="/prompts/" class="hidden text-sm font-[var(--font-display)] font-medium text-[var(--color-accent)] hover:underline sm:block">
          View all prompts &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredPrompts.map((prompt) => (
          <PromptCard
            title={prompt.data.title}
            slug={prompt.data.slug}
            description={prompt.data.description}
            tool={prompt.data.tool}
            category={prompt.data.category}
            difficulty={prompt.data.difficulty}
            tags={prompt.data.tags}
            isFeatured={prompt.data.isFeatured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Latest Prompts -->
  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-16 border-t border-[var(--color-border)]" data-reveal>
    <div class="mb-10 flex items-end justify-between">
      <div class="section-head-copy">
        <h2 class="text-[var(--color-text-primary)]">Latest Prompts</h2>
        <p class="mt-2 max-w-xl text-[var(--color-text-secondary)]">Recently added to the library</p>
      </div>
      <a href="/prompts/" class="hidden text-sm font-[var(--font-display)] font-medium text-[var(--color-accent)] hover:underline sm:block">
        View all prompts &rarr;
      </a>
    </div>

    <div class="surface-glass-prominent divide-y divide-[var(--glass-border)] rounded-[var(--radius-lg)]">
      {latestPrompts.map((prompt) => (
        <a
          href={`/prompts/${prompt.data.slug}/`}
          class="flex min-h-[4.75rem] items-center justify-between gap-4 px-5 py-4 transition-colors hover:bg-[var(--glass-highlight-soft)]"
        >
          <div class="flex items-center gap-3 min-w-0">
            <span class="font-[var(--font-display)] font-semibold text-[var(--color-text-primary)] truncate">
              {prompt.data.title}
            </span>
            <Badge variant="teal" size="sm">{toolDisplayNames[prompt.data.tool] || prompt.data.tool}</Badge>
            <span class="hidden text-sm text-[var(--color-text-muted)] sm:inline capitalize">
              {prompt.data.category.replace(/-/g, ' ')}
            </span>
          </div>
          <span class="shrink-0 text-[var(--color-accent)] font-medium">&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Popular Prompt Collections -->
  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-16 border-t border-[var(--color-border)]" data-reveal>
    <div class="mb-10 flex items-end justify-between">
      <div class="section-head-copy">
        <h2 class="text-[var(--color-text-primary)]">Popular Prompt Collections</h2>
        <p class="mt-2 max-w-xl text-[var(--color-text-secondary)]">Curated collections for the most popular tools and audiences</p>
      </div>
    </div>

    <CollectionGrid collections={collections} client:visible />
  </section>

  <!-- Cross-Promo -->
  <section class="mx-auto max-w-7xl px-[var(--space-page)] pb-16" data-reveal>
    <div class="surface-glass-prominent rounded-[var(--radius-lg)] p-8 text-center">
      <h2 class="text-xl font-[var(--font-display)] font-bold text-[var(--color-text-primary)]">
        Looking for AI tools?
      </h2>
      <p class="mt-2 text-[var(--color-text-secondary)]">
        Explore 200+ curated AI tools on our sister site
      </p>
      <a
        href="https://aitoolindex.io"
        class="surface-glass-ui mt-4 inline-flex items-center justify-center rounded-[var(--radius-md)] px-5 py-2.5 text-sm font-[var(--font-display)] font-medium text-[var(--color-text-primary)] transition-all duration-200 hover:text-[var(--color-accent)]"
      >
        Visit AIToolIndex.io &rarr;
      </a>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <NewsletterSignup />

  <Footer slot="footer" />
</BaseLayout>
