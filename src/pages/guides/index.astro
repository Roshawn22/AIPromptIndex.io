---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import Badge from '../../components/ui/Badge.astro';
import Tag from '../../components/ui/Tag.astro';
import Button from '../../components/ui/Button.astro';

const guides = (await getCollection('guides'))
  .filter((guide) => guide.data.draft !== true)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const difficultyColor = {
  beginner: 'green' as const,
  intermediate: 'yellow' as const,
  advanced: 'red' as const,
};
---

<BaseLayout
  title="Prompt Engineering Guides"
  description="Learn how to write better AI prompts with our free guides. Tips, techniques, and best practices for ChatGPT, Claude, Midjourney, and more."
>
  <Header slot="header" />

  <section class="mx-auto max-w-4xl px-[var(--space-page)] py-16">
    <div class="text-center mb-12">
      <h1>Prompt Engineering Guides</h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)]">
        Learn how to write better AI prompts with our free guides.
      </p>
    </div>

    {guides.length > 0 ? (
      <div class="space-y-6">
        {guides.map((guide) => {
          const formattedDate = guide.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a
              href={`/guides/${guide.id}/`}
              class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6 transition-colors hover:bg-[var(--color-surface-2)] hover:border-[var(--color-accent-muted)]"
            >
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <Badge variant={difficultyColor[guide.data.difficulty]} size="sm">
                  {guide.data.difficulty}
                </Badge>
                <span class="text-xs text-[var(--color-text-muted)]">{formattedDate}</span>
              </div>
              <h2 class="text-xl font-[var(--font-display)] font-semibold text-[var(--color-text-primary)] mb-2">
                {guide.data.title}
              </h2>
              <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-3">
                {guide.data.description}
              </p>
              {guide.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {guide.data.tags.slice(0, 4).map((tag) => (
                    <span class="inline-flex items-center px-2 py-0.5 text-xs font-[var(--font-display)] rounded-[var(--radius-sm)] bg-[var(--color-surface-2)] text-[var(--color-text-muted)] border border-[var(--color-border-subtle)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-lg text-[var(--color-text-muted)] mb-6">No guides yet. Check back soon!</p>
        <Button href="/prompts/" variant="outline">Browse Prompts Instead</Button>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</BaseLayout>
