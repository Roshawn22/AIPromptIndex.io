---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import NewsletterSignup from '../../components/common/NewsletterSignup.astro';
import bestofPages from '../../data/seo/bestof-pages.json';
import { getPromptsForBestOf, isFeaturedBestOfFilter } from '../../lib/bestof';

const allPrompts = await getCollection('prompts');

const roundupsWithCounts = bestofPages.map((r: any) => {
  const count = getPromptsForBestOf(allPrompts, r.filter).length;
  return { ...r, count };
});

const byTool = roundupsWithCounts.filter((r: any) => r.filter.tool && !r.filter.category);
const byCategory = roundupsWithCounts.filter((r: any) => r.filter.category && !r.filter.tool);
const featuredCollections = roundupsWithCounts.filter((r: any) => isFeaturedBestOfFilter(r.filter));
---

<BaseLayout
  title="Best AI Prompts by Tool & Category"
  description="Curated collections of the best AI prompts organized by tool and category. Copy and paste ready prompts for ChatGPT, Claude, Midjourney, and more."
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Best Prompts' },
    ]} />

    <div class="mb-10">
      <h1 class="mb-2">Best AI Prompts</h1>
      <p class="text-lg text-[var(--color-text-secondary)]">
        Curated collections of the best prompts, organized by tool and category.
      </p>
    </div>

    {featuredCollections.length > 0 && (
      <div class="mb-12">
        <h2 class="mb-6 text-xl">Featured Collections</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuredCollections.map((r: any) => (
            <a
              href={`/best/${r.slug}/`}
              class="group block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6 transition-all duration-200 hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-accent-muted)]"
            >
              <h3 class="font-[var(--font-display)] text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                {r.title}
              </h3>
              <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">{r.metaDescription || r.description}</p>
              <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">
                {r.count} {r.count === 1 ? 'prompt' : 'prompts'}
                <svg class="ml-1 inline h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- By Tool -->
    <div class="mb-12">
      <h2 class="mb-6 text-xl">By Tool</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {byTool.map((r) => (
          <a
            href={`/best/${r.slug}/`}
            class="group block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6 transition-all duration-200 hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-accent-muted)]"
          >
            <h3 class="font-[var(--font-display)] text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
              {r.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">{r.description}</p>
            <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">
              {r.count} {r.count === 1 ? 'prompt' : 'prompts'}
              <svg class="ml-1 inline h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>

    <!-- By Category -->
    <div class="mb-12">
      <h2 class="mb-6 text-xl">By Category</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {byCategory.map((r) => (
          <a
            href={`/best/${r.slug}/`}
            class="group block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6 transition-all duration-200 hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-accent-muted)]"
          >
            <h3 class="font-[var(--font-display)] text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
              {r.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">{r.description}</p>
            <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">
              {r.count} {r.count === 1 ? 'prompt' : 'prompts'}
              <svg class="ml-1 inline h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterSignup />

  <Footer slot="footer" />
</BaseLayout>
