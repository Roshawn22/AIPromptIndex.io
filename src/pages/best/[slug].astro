---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import { TOOL_DISPLAY_NAMES as toolDisplayNames, CATEGORY_DISPLAY_NAMES as categoryDisplayNames } from '../../lib/constants';
import PromptCard from '../../components/prompt/PromptCard.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import NewsletterSignup from '../../components/common/NewsletterSignup.astro';
import bestofPages from '../../data/seo/bestof-pages.json';

export async function getStaticPaths() {
  return bestofPages.map((r: any) => ({
    params: { slug: r.slug },
    props: { roundup: r, allRoundups: bestofPages },
  }));
}

const { roundup, allRoundups } = Astro.props;

const allPrompts = await getCollection('prompts');

const prompts = allPrompts
  .filter((p) => {
    if (roundup.filter.tool && roundup.filter.category) {
      return p.data.tool === roundup.filter.tool && p.data.category === roundup.filter.category;
    }
    if (roundup.filter.tool && roundup.filter.tag) {
      return p.data.tool === roundup.filter.tool && p.data.tags?.includes(roundup.filter.tag);
    }
    if (roundup.filter.tool) return p.data.tool === roundup.filter.tool;
    if (roundup.filter.category) return p.data.category === roundup.filter.category;
    if (roundup.filter.tag) return p.data.tags?.includes(roundup.filter.tag);
    if (roundup.filter.sort === 'top-rated') return true;
    return false;
  })
  .sort((a, b) => {
    if (a.data.isFeatured && !b.data.isFeatured) return -1;
    if (!a.data.isFeatured && b.data.isFeatured) return 1;
    return new Date(b.data.dateAdded).getTime() - new Date(a.data.dateAdded).getTime();
  });

const relatedRoundups = allRoundups.filter((r: any) => r.slug !== roundup.slug).slice(0, 4);

const filterType = roundup.filter.tool ? 'tool' : roundup.filter.category ? 'category' : 'collection';
const filterValue = roundup.filter.tool || roundup.filter.category;
const linkTarget = filterType === 'tool' ? `/tools/${filterValue}/` : `/categories/${filterValue}/`;

const displayName = filterType === 'tool'
  ? toolDisplayNames[filterValue!] || filterValue
  : filterType === 'category'
    ? categoryDisplayNames[filterValue!] || filterValue
    : roundup.title;

const seoTitle = roundup.metaTitle && roundup.metaTitle.length <= 60 ? roundup.metaTitle : roundup.title;
const seoDescription = roundup.metaDescription || roundup.description;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://aipromptindex.io';

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: roundup.title,
  description: roundup.description,
  numberOfItems: prompts.length,
  itemListElement: prompts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.data.title,
    url: `${siteUrl}/prompts/${p.data.slug}/`,
  })),
};

const allJsonLd: Record<string, unknown>[] = [itemListJsonLd];

if (roundup.faqs && roundup.faqs.length > 0) {
  allJsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: roundup.faqs.map((faq: any) => ({
      '@type': 'Question',
      name: faq.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.a,
      },
    })),
  });
}

const firstBatch = prompts.slice(0, 5);
const secondBatch = prompts.slice(5);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  jsonLd={allJsonLd}
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-8">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Best Prompts', href: '/best/' },
      { label: roundup.title },
    ]} />

    <!-- Hero -->
    <div class="mb-10">
      <h1 class="mb-2">{roundup.title}</h1>
      <p class="text-lg text-[var(--color-text-secondary)]">
        {prompts.length} curated prompts — copy & paste ready
      </p>
      {roundup.intro ? (
        <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">{roundup.intro}</p>
      ) : (
        <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">{roundup.description}</p>
      )}
    </div>

    {prompts.length > 0 ? (
      <>
        <!-- First batch: prompts 1-5 -->
        <ol class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 list-none p-0">
          {firstBatch.map((prompt, i) => (
            <li class="relative">
              <span class="absolute -top-2 -left-2 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-accent)] text-xs font-bold text-white shadow-md">
                {i + 1}
              </span>
              <PromptCard
                title={prompt.data.title}
                slug={prompt.data.slug}
                description={prompt.data.description}
                tool={prompt.data.tool}
                category={prompt.data.category}
                difficulty={prompt.data.difficulty}
                tags={prompt.data.tags}
                isFeatured={prompt.data.isFeatured}
              />
            </li>
          ))}
        </ol>

        <!-- Newsletter CTA (midway) -->
        {prompts.length > 5 && (
          <div class="my-10">
            <NewsletterSignup
              heading={`Get More ${displayName} Prompts Weekly`}
              subheading="New prompts, tips, and guides delivered to your inbox every week. Free."
              compact
            />
          </div>
        )}

        <!-- Second batch: prompts 6+ -->
        {secondBatch.length > 0 && (
          <ol start={6} class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 list-none p-0">
            {secondBatch.map((prompt, i) => (
              <li class="relative">
                <span class="absolute -top-2 -left-2 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-accent)] text-xs font-bold text-white shadow-md">
                  {i + 6}
                </span>
                <PromptCard
                  title={prompt.data.title}
                  slug={prompt.data.slug}
                  description={prompt.data.description}
                  tool={prompt.data.tool}
                  category={prompt.data.category}
                  difficulty={prompt.data.difficulty}
                  tags={prompt.data.tags}
                  isFeatured={prompt.data.isFeatured}
                />
              </li>
            ))}
          </ol>
        )}

        <!-- Link to full tool/category page -->
        {filterValue && (
          <div class="mt-8 text-center">
            <a
              href={linkTarget}
              class="inline-flex items-center gap-2 font-[var(--font-display)] font-semibold text-[var(--color-accent)] hover:underline"
            >
              See all {displayName} prompts
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        )}
      </>
    ) : (
      <p class="text-center text-[var(--color-text-muted)] py-12">
        No prompts in this roundup yet. <a href="/submit/" class="text-[var(--color-accent)] hover:underline">Submit one!</a>
      </p>
    )}

    <!-- Tips section -->
    {roundup.tips && roundup.tips.length > 0 && (
      <div class="mt-16 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-8">
        <h2 class="mb-4 text-xl">How to Get the Best Results</h2>
        <ul class="space-y-3">
          {roundup.tips.map((tip: string) => (
            <li class="flex items-start gap-3 text-[var(--color-text-secondary)]">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- FAQ section -->
    {roundup.faqs && roundup.faqs.length > 0 && (
      <div class="mt-16">
        <h2 class="mb-6 text-xl">Frequently Asked Questions</h2>
        <dl class="space-y-6">
          {roundup.faqs.map((faq: any) => (
            <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6">
              <dt class="font-[var(--font-display)] font-semibold text-[var(--color-text-primary)]">{faq.q}</dt>
              <dd class="mt-2 text-[var(--color-text-secondary)]">{faq.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}

    <!-- Related roundups -->
    <div class="mt-16 border-t border-[var(--color-border)] pt-10">
      <h2 class="mb-6 text-xl">You Might Also Like</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {relatedRoundups.map((r: any) => (
          <a
            href={`/best/${r.slug}/`}
            class="block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-5 transition-all duration-200 hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-accent-muted)]"
          >
            <h3 class="font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
              {r.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">{r.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom Newsletter CTA -->
  <NewsletterSignup />

  <Footer slot="footer" />
</BaseLayout>
