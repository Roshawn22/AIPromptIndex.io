---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';

const categories = await getCollection('categories');
const prompts = await getCollection('prompts');

const categoriesWithCounts = categories
  .sort((a, b) => a.data.order - b.data.order)
  .map((cat) => ({
    ...cat.data,
    promptCount: prompts.filter((p) => p.data.category === cat.data.slug).length,
  }));
---

<BaseLayout
  title="Prompts by Category"
  description="Browse AI prompts by use case. Find prompts for writing, coding, marketing, image generation, business, and more."
>
  <Header slot="header" />

  <section class="mx-auto max-w-7xl px-[var(--space-page)] py-12">
    <div class="mb-10">
      <h1>Prompts by Category</h1>
      <p class="mt-2 text-lg text-[var(--color-text-secondary)]">
        Find the perfect prompt for your use case
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {categoriesWithCounts.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="group rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-1)] p-6 transition-all duration-200 hover:shadow-[var(--shadow-card-hover)] hover:border-[var(--color-accent-muted)]"
        >
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-glow)]">
            <svg class="h-5 w-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
          </div>
          <h3 class="font-[var(--font-display)] text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
            {cat.name}
          </h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)] line-clamp-2">{cat.description}</p>
          <p class="mt-3 text-sm font-[var(--font-display)] font-medium text-[var(--color-accent)]">
            {cat.promptCount} prompt{cat.promptCount !== 1 ? 's' : ''}
          </p>
        </a>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
