---
import Badge from '../ui/Badge.astro';
import Tag from '../ui/Tag.astro';

interface Props {
  title: string;
  slug: string;
  description: string;
  tool: string;
  category: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  tags?: string[];
  isFeatured?: boolean;
  class?: string;
}

const {
  title,
  slug,
  description,
  tool,
  difficulty,
  tags = [],
  isFeatured = false,
  class: className,
} = Astro.props;

const difficultyColor = {
  beginner: 'green' as const,
  intermediate: 'yellow' as const,
  advanced: 'red' as const,
};

import { TOOL_DISPLAY_NAMES as toolDisplayNames } from '../../lib/constants';

const truncatedDescription = description.length > 150
  ? description.slice(0, 150).trimEnd() + '...'
  : description;
---

<a
  href={`/prompts/${slug}/`}
  class:list={[
    'surface-glass-ui glass-card-grid group h-full overflow-hidden rounded-[var(--radius-card)] transition-all duration-300 will-change-transform',
    'hover:-translate-y-0.5 hover:shadow-[var(--shadow-card-hover)] active:scale-[0.98]',
    isFeatured && 'ring-1 ring-[var(--color-accent)]/20',
    className,
  ]}
>
  <!-- Top badges -->
  <div class="glass-card-meta">
    <Badge variant="teal" size="sm">{toolDisplayNames[tool] || tool}</Badge>
    <Badge variant={difficultyColor[difficulty]} size="sm">{difficulty}</Badge>
    {isFeatured && <Badge variant="purple" size="sm">Featured</Badge>}
  </div>

  <!-- Title -->
  <h3 class="glass-card-title line-clamp-2 font-[var(--font-display)] text-base font-semibold text-[var(--color-text-primary)] transition-colors group-hover:text-[var(--color-accent)]">
    {title}
  </h3>

  <!-- Description -->
  <p class="glass-card-body line-clamp-3 text-sm text-[var(--color-text-secondary)]">
    {truncatedDescription}
  </p>

  <!-- Tags -->
  <div class="glass-card-footer">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <Tag>{tag}</Tag>
        ))}
      </div>
    )}
  </div>
</a>
