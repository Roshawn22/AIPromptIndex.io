---
import { BADGE_COLORS, type BadgeColor } from '../../lib/badge-colors';

interface Props {
  variant?: BadgeColor;
  color?: BadgeColor;
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant,
  color,
  size = 'sm',
  class: className,
} = Astro.props;
const tone = variant ?? color ?? 'neutral';

const sizes: Record<string, string> = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
};
---

<span class:list={[
  'inline-flex items-center font-[var(--font-display)] font-medium rounded-full border transition-colors duration-200',
  BADGE_COLORS[tone],
  sizes[size],
  className,
]}>
  <slot />
</span>
