---
interface Props {
  size?: 'sm' | 'md';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

const containerSize = size === 'sm' ? 'h-6 w-6' : 'h-8 w-8';
const iconSize = size === 'sm' ? 'h-3 w-3' : 'h-4 w-4';
---

<div class:list={[
  'flex items-center justify-center rounded-[var(--radius-sm)] bg-gradient-to-br from-teal-500 to-teal-700 shadow-[0_0_16px_rgba(13,148,136,0.3)]',
  containerSize,
  className,
]}>
  <svg class:list={[iconSize, 'text-white']} fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M6 4l8 8-8 8" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M10.5 15.5h7" stroke="#5eead4" stroke-width="2.2" stroke-linecap="round"/>
  </svg>
</div>
