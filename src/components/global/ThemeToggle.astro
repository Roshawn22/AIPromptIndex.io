---
// ThemeToggle — light-first, dark class toggle
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark/light mode"
  class="relative flex items-center justify-center w-11 h-11 rounded-[var(--radius-md)] bg-[var(--color-surface-2)] border border-[var(--color-border)] hover:bg-[var(--color-surface-3)] transition-colors"
>
  <!-- Moon icon (shown in light mode — click to go dark) -->
  <svg
    class="theme-icon-moon w-4 h-4 text-neutral-500"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <!-- Sun icon (shown in dark mode — click to go light) -->
  <svg
    class="theme-icon-sun w-4 h-4 text-amber-400 hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const sun = btn.querySelector('.theme-icon-sun') as HTMLElement;
    const moon = btn.querySelector('.theme-icon-moon') as HTMLElement;

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      moon.classList.toggle('hidden', isDark);
      sun.classList.toggle('hidden', !isDark);
    }

    updateIcons();

    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const isCurrentlyDark = html.classList.contains('dark');
      const newTheme = isCurrentlyDark ? 'light' : 'dark';

      html.classList.add('theme-transition-disabled');
      html.classList.remove('dark', 'light');
      if (newTheme === 'dark') html.classList.add('dark');
      localStorage.setItem('api-theme', newTheme);
      updateIcons();

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          html.classList.remove('theme-transition-disabled');
        });
      });
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
