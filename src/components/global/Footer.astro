---
const directoryLinks = [
  { href: '/prompts/', label: 'All Prompts' },
  { href: '/categories/writing/', label: 'Writing Prompts' },
  { href: '/categories/coding/', label: 'Coding Prompts' },
  { href: '/categories/marketing/', label: 'Marketing Prompts' },
  { href: '/categories/image-generation/', label: 'Image Prompts' },
  { href: '/categories/business/', label: 'Business Prompts' },
];

const resourceLinks = [
  { href: '/guides/', label: 'Guides' },
  { href: '/blog/', label: 'Blog' },
  { href: '/submit/', label: 'Submit a Prompt' },
];

const bestPromptsLinks = [
  { href: '/best/', label: 'All Best-Of Lists' },
  { href: '/best/chatgpt-prompts/', label: 'Best ChatGPT Prompts' },
  { href: '/best/coding-prompts/', label: 'Best Coding Prompts' },
  { href: '/best/writing-prompts/', label: 'Best Writing Prompts' },
  { href: '/best/midjourney-prompts/', label: 'Best Midjourney Prompts' },
  { href: '/prompts/chatgpt/marketing/', label: 'ChatGPT Marketing Prompts' },
  { href: '/prompts/for/teachers/', label: 'AI Prompts for Teachers' },
  { href: '/best/dall-e-art-prompts/', label: 'DALL-E Prompts' },
  { href: '/best/prompt-templates/', label: 'Prompt Templates' },
  { href: '/prompts/cursor/coding/', label: 'Cursor Coding Prompts' },
];

const toolLinks = [
  { href: '/tools/chatgpt/', label: 'ChatGPT Prompts' },
  { href: '/tools/claude/', label: 'Claude Prompts' },
  { href: '/tools/midjourney/', label: 'Midjourney Prompts' },
  { href: '/tools/gemini/', label: 'Gemini Prompts' },
  { href: '/tools/cursor/', label: 'Cursor Prompts' },
];

const communityLinks = [
  { href: 'https://www.skool.com/ai-freedom-lab', label: 'AI Freedom Lab', external: true },
  { href: 'https://www.youtube.com/@AIHeavy', label: 'AI Heavy YouTube', external: true },
  { href: 'https://aitoolindex.io', label: 'AIToolIndex.io', external: true },
];

const companyLinks = [
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  { href: '/privacy/', label: 'Privacy Policy' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface-1)]">
  <div class="mx-auto max-w-7xl px-[var(--space-page)] py-16">
    <!-- Cross-promo -->
    <div class="mb-12 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-2)] p-6 text-center">
      <p class="text-sm text-[var(--color-text-secondary)]">
        Looking for AI tools? Visit
        <a href="https://aitoolindex.io" target="_blank" rel="noopener noreferrer" class="font-[var(--font-display)] font-semibold text-[var(--color-accent)] hover:underline">
          AIToolIndex.io
        </a>
        — The AI Tools Directory
      </p>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-6">
      <!-- Directory -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          Directory
        </h3>
        <ul class="space-y-2.5">
          {directoryLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          Resources
        </h3>
        <ul class="space-y-2.5">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Best Prompts -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          Best Prompts
        </h3>
        <ul class="space-y-2.5">
          {bestPromptsLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          By Tool
        </h3>
        <ul class="space-y-2.5">
          {toolLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          Community
        </h3>
        <ul class="space-y-2.5">
          {communityLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="mb-4 font-[var(--font-display)] text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">
          Company
        </h3>
        <ul class="space-y-2.5">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-[var(--color-border)] pt-8 sm:flex-row">
      <div class="flex items-center gap-2">
        <div class="flex h-6 w-6 items-center justify-center rounded-[var(--radius-sm)] bg-gradient-to-br from-teal-500 to-teal-700">
          <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M8 6h13M8 12h9M8 18h11" />
            <circle cx="4" cy="6" r="1.5" fill="currentColor" />
            <circle cx="4" cy="12" r="1.5" fill="currentColor" />
            <circle cx="4" cy="18" r="1.5" fill="currentColor" />
          </svg>
        </div>
        <span class="font-[var(--font-display)] text-sm font-semibold text-[var(--color-text-primary)]">
          AIPromptIndex
        </span>
      </div>

      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} AIPromptIndex. All rights reserved.
      </p>

      <div class="flex items-center gap-3">
        <!-- Twitter / X -->
        <a href="https://twitter.com/aipromptindex" target="_blank" rel="noopener noreferrer" aria-label="Follow on X (Twitter)" class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text-primary)]">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <!-- YouTube -->
        <a href="https://youtube.com/@AIHeavyOfficial" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube" class="flex h-8 w-8 items-center justify-center rounded-[var(--radius-sm)] text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text-primary)]">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
