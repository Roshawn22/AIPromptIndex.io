---
interface Props {
  heading?: string;
  subheading?: string;
  compact?: boolean;
}

const {
  heading = 'Get the Best AI Prompts Weekly',
  subheading = 'Curated prompts, tips, and guides delivered to your inbox every week. Free.',
  compact = false,
} = Astro.props;

const beehiivPublicationId = (
  import.meta.env.PUBLIC_BEEHIIV_PUBLICATION_ID as string | undefined
)?.trim();
---

<section data-reveal class:list={[
  'border-t border-[var(--glass-border)] bg-transparent',
  !compact && 'py-16',
  compact && 'py-8',
]}>
  <div class:list={[
    'mx-auto',
    !compact && 'max-w-7xl px-[var(--space-page)]',
    compact && 'max-w-md px-4',
  ]}>
    <div class:list={[
      'surface-glass-prominent relative mx-auto overflow-hidden rounded-[var(--radius-lg)]',
      !compact && 'max-w-xl p-8',
      compact && 'p-5',
    ]}>
      <div class="newsletter-sweep absolute inset-x-0 top-0 h-[2px]" aria-hidden="true"></div>

      <div class="text-center">
        <div class:list={['newsletter-float nl-stagger nl-stagger-1 mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full border border-[var(--glass-border)] bg-[var(--glass-highlight)]', compact && 'h-8 w-8 mb-3']}>
          <svg class:list={['text-[var(--color-accent)]', !compact && 'h-5 w-5', compact && 'h-4 w-4']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="M22 6l-10 7L2 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <h2 class:list={[
          'nl-stagger nl-stagger-2 text-[var(--color-text-primary)]',
          compact && '!text-lg',
        ]}>{heading}</h2>
        <p class:list={[
          'nl-stagger nl-stagger-3 mt-2 text-[var(--color-text-secondary)]',
          compact && 'text-sm',
        ]}>{subheading}</p>
      </div>

      {beehiivPublicationId ? (
        <div class:list={['nl-stagger nl-stagger-4 mx-auto', !compact && 'mt-6 max-w-sm', compact && 'mt-4']}>
          <div class="surface-glass-ui overflow-hidden rounded-[var(--radius-md)] p-1">
          <iframe
            src={`https://embeds.beehiiv.com/subscribe/${beehiivPublicationId}?slim=true`}
            data-test-id="beehiiv-embed"
            title="Subscribe to the AIPromptIndex newsletter"
            style="margin: 0; border-radius: 0 !important; background-color: transparent;"
            frameborder="0"
            scrolling="no"
            class="w-full overflow-hidden rounded-[var(--radius-md)]"
            height="52"
          ></iframe>
          </div>

          <p class="mt-3 text-center text-xs text-[var(--color-text-muted)]">
            No spam, ever. Unsubscribe anytime.
          </p>
        </div>
      ) : (
        <div class:list={['nl-stagger nl-stagger-4 mx-auto', !compact && 'mt-6 max-w-sm', compact && 'mt-4']}>
          <div class="surface-glass-ui rounded-[var(--radius-md)] px-4 py-3 text-center text-sm text-[var(--color-text-secondary)]">
            Newsletter signup is temporarily unavailable.
          </div>

          <p class="mt-3 text-center text-xs text-[var(--color-text-muted)]">
            Add `PUBLIC_BEEHIIV_PUBLICATION_ID` to re-enable subscriptions.
          </p>
        </div>
      )}
    </div>
  </div>
</section>
