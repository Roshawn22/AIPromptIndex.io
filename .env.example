# Convex — Real-time backend for voting, submissions, analytics
# Get this from: https://dashboard.convex.dev
PUBLIC_CONVEX_URL=

# Clerk — Authentication
# Get this from: https://dashboard.clerk.com
PUBLIC_CLERK_PUBLISHABLE_KEY=

# Convex server-side Clerk auth
# Set these in Convex with: npx convex env set CLERK_JWT_ISSUER_DOMAIN <value>
# and npx convex env set CLERK_ADMIN_USER_IDS <comma-separated Clerk user IDs>
CLERK_JWT_ISSUER_DOMAIN=
CLERK_ADMIN_USER_IDS=

# Google Analytics 4
# Get this from: https://analytics.google.com
PUBLIC_GA_MEASUREMENT_ID=

# Beehiiv Newsletter
# Get this from: https://app.beehiiv.com → Settings → Publication ID
PUBLIC_BEEHIIV_PUBLICATION_ID=

# Google Search Console verification
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Site URL (used for canonical URLs, OG images)
PUBLIC_SITE_URL=https://aipromptindex.io

# --- SEO Data Pipeline ---

# Ahrefs API — SEO data pulls (site-explorer, brand-radar)
# Get this from: https://app.ahrefs.com/user/api
AHREFS_API_TOKEN=

# SEMRush API — SEO data pulls (domain analytics, keyword research)
# Get this from: https://www.semrush.com/api-analytics/
SEMRUSH_API_KEY=

# Google Service Account — GSC + GA4 data pulls
# Path to JSON key file or inline JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Search Console property for data pulls
GOOGLE_SEARCH_CONSOLE_PROPERTY=sc-domain:aipromptindex.io

# Google Analytics 4 property ID (numeric) for data pulls
GOOGLE_ANALYTICS_PROPERTY_ID=

# Site verification meta tags
PUBLIC_AHREFS_SITE_VERIFICATION=
PUBLIC_SEMRUSH_SITE_VERIFICATION=
